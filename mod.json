{
	"geode": "5.3.0",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "memeking16.chatgd",
	"name": "ChatGD",
	"version": "v1.1.2",
	"developers": [
		"MEMEKING16",
		"Axiom"
	],
	"description": "A mod that adds a chat as if you were live streaming",
	"dependencies": {
        "geode.node-ids": ">=v1.23.0"
    },
	"links": {
        "source": "https://github.com/MEME-KING16/ChatGD",
        "community": "https://discord.gg/X5ZU4cdnZt"
    },
	"issues": {
		"info": "If you have an issue with the mod please report it here!",
		"url": "https://github.com/MEME-KING16/ChatGD/issues"
	},
	"tags": [
		"gameplay",
		"interface"
	],
	"settings": {
        "enabled-in-practice": {
            "name": "Enabled in practice mode",
            "type": "bool",
            "default": false
        },
		"custom-chatters": {
			"name": "Custom Chatters",
			"type": "string",
			"default": "",
			"description": "list of custom chatters that u want added to the chat seperated by spaces"
		},
		"x-off": {
			"name": "Chat x offset",
			"type": "int",
			"default": 0
		},
		"y-off": {
			"name": "Chat y offset",
			"type": "int",
			"default": 0
		},
		"viewer-count": {
			"name": "Viewer Count",
			"type": "int",
			"default": 100
		},
		"enabled-by-default": {
			"name": "Is Enabled by Default",
			"type": "bool",
			"default": true
		},
		"font": {
			"name": "Font",
			"type": "string",
			"one-of": ["bigFont", "gjFont01", "gjFont02", "gjFont03", "gjFont04", "gjFont05", "gjFont06", "gjFont07", "gjFont08", "gjFont09", "gjFont10", "gjFont11", "gjFont12", "gjFont13", "gjFont14", "gjFont15", "gjFont16", "gjFont17", "gjFont18", "gjFont19", "gjFont20", "gjFont21", "gjFont22", "gjFont23", "gjFont24", "gjFont25", "gjFont26", "gjFont27", "gjFont28", "gjFont29", "gjFont30", "gjFont31", "gjFont32", "gjFont33", "gjFont34", "gjFont35", "gjFont36", "gjFont37", "gjFont38", "gjFont39", "gjFont40", "gjFont41", "gjFont42", "gjFont43", "gjFont44", "gjFont45", "gjFont46", "gjFont47", "gjFont48", "gjFont49", "gjFont50", "gjFont51", "gjFont52", "gjFont53", "gjFont54", "gjFont55", "gjFont56", "gjFont57", "gjFont58", "gjFont59", "gjFont60"],
			"default": "bigFont"
		}
    }
}